<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>JUMBO RADIO</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #121212;
  color: white;
  text-align: center;
}

/* CONTENEDOR */
.container {
  margin-top: 80px;
}

/* LOGO AVIÓN */
.plane {
  font-size: 60px;
  animation: volar 5s linear infinite;
}

/* ANIMACIÓN */
@keyframes volar {
  0% { transform: translateX(-200px); }
  100% { transform: translateX(200px); }
}

/* TARJETA */
.player {
  background: #1db954;
  padding: 30px;
  border-radius: 20px;
  display: inline-block;
  margin-top: 30px;
  color: black;
}

/* BOTÓN */
audio {
  width: 300px;
  margin-top: 15px;
}

/* TEXO */
h1 {
  font-size: 40px;
}

p {
  color: #ccc;
}
</style>

</head>
<body>

<div class="container">

  <!-- AVIÓN -->
  <div class="plane">✈️</div>

  <h1>JUMBO RADIO</h1>
  <p>Transmitiendo en vivo 24/7</p>

  <!-- REPRODUCTOR -->
  <div class="player">
    <h3>🔴 EN VIVO</h3>

    <audio controls autoplay>
      <source src=https:"//jumbo0404.github.io/JUMBO1/"type="audio/mpeg">
    </audio>
  </div>

</div>

</body>
</html>
